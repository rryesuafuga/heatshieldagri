# HeatShield USSD Configuration

# Server settings
HOST=0.0.0.0
PORT=8080

# USSD service code
USSD_SERVICE_CODE=*384*HEAT#

# Database
DATABASE_URL=postgres://user:password@localhost:5432/heatshield

# Redis for sessions
REDIS_URL=redis://localhost:6379

# Africa's Talking API
AFRICAS_TALKING_API_KEY=your_api_key_here
AFRICAS_TALKING_USERNAME=your_username_here

# HeatShield API
HEATSHIELD_API_URL=http://localhost:3000/api/v1

# Session timeout (seconds)
SESSION_TIMEOUT_SECS=300

# Logging
RUST_LOG=info
